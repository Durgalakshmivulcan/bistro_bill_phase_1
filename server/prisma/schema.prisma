  authorStaff   Staff?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  tags          BlogTag[]
  revisions     BlogRevision[]

  @@unique([businessOwnerId, slug])
  @@index([businessOwnerId])
  @@index([categoryId])
  @@index([authorId])
  @@index([status])
  @@index([publishedAt])
}

// BlogRevision - Content version history for blog posts (US-163)
model BlogRevision {
  id         String   @id @default(uuid())
  blogId     String
  content    String   @db.Text
  title      String
  excerpt    String?
  authorId   String?
  authorName String?
  createdAt  DateTime @default(now())

  // Relations
  blog        Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)
  authorStaff Staff? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([blogId])
  @@index([createdAt])
}

// ============================================
// Sales Settings Tables (US-133)
// ============================================

// SalesChannel - Sales channels like Dine In, Take Away, Delivery, etc.
model SalesChannel {
