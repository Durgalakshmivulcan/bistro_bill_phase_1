  businessOwnerId String
  name            String
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)

  @@unique([businessOwnerId, name])
  @@index([businessOwnerId])
}

// Aggregator - Online aggregator platforms like Uber Eats, Swiggy, Zomato
model Aggregator {
  id              String   @id @default(uuid())
  businessOwnerId String
  name            String
  logo            String?
  merchantId      String?
  apiKey          String?
  apiEndpoint     String?
  callbackUrl     String?
  isConnected     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)

  @@unique([businessOwnerId, name])
  @@index([businessOwnerId])
}

// MeasuringUnit - Global measuring units (managed by SuperAdmin)
model MeasuringUnit {
  id        String   @id @default(uuid())
  quantity  String // e.g., "Length", "Weight", "Volume"
  unit      String // e.g., "Meter", "Kilogram", "Liter"
  symbol    String // e.g., "m", "kg", "L"
  createdAt DateTime @default(now())
}

// ============================================
// PHASE 10: Analytics - Sales Anomaly Detection (US-216)
// ============================================

model SalesAnomaly {
  id                 String    @id @default(uuid())
  businessOwnerId    String
  branchId           String    @default("")
  date               DateTime  @db.Date
  type               String // 'high' or 'low'
  actualValue        Decimal   @db.Decimal(12, 2)
  expectedValue      Decimal   @db.Decimal(12, 2)
  deviation          Decimal   @db.Decimal(10, 2) // percentage deviation
  standardDeviations Decimal   @db.Decimal(6, 2) // number of standard deviations
  resolved           Boolean   @default(false)
  resolvedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)

  @@unique([businessOwnerId, branchId, date])
  @@index([businessOwnerId])
  @@index([date])
  @@index([resolved])
}

// ============================================
// PHASE 10: Analytics - Report Sharing (US-219)
// ============================================

model ReportShare {
  id              String    @id @default(uuid())
  businessOwnerId String
  reportType      String // 'sales' | 'products' | 'customers' | 'staff'
  reportConfig    Json // date ranges, filters, comparison settings
  reportData      Json // snapshot of report data at time of sharing
  shareToken      String    @unique @default(uuid())
  password        String? // optional password protection (hashed)
  expiresAt       DateTime?
  viewCount       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)

  @@index([businessOwnerId])
  @@index([shareToken])
  @@index([expiresAt])
}

// ============================================
// PHASE 10: Analytics - Report Comments (US-220)
// ============================================

model ReportComment {
  id              String    @id @default(uuid())
  businessOwnerId String
  reportType      String // 'sales' | 'products' | 'customers' | 'staff'
  reportConfig    Json // date ranges, filters used to identify the report
  userId          String // ID of user who posted (staff or business owner)
  userName        String // Display name at time of comment
  comment         String // Markdown-formatted comment text
  mentions        Json? // Array of { userId, userName } for @mentions
  editedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)

  @@index([businessOwnerId])
  @@index([reportType])
  @@index([createdAt])
}

// ============================================
// PHASE 10: Custom Report Builder (US-203)
// ============================================

model CustomReport {
  id              String    @id @default(uuid())
  businessOwnerId String
  name            String
  description     String?
  reportType      String    // 'Sales' | 'Products' | 'Customers' | 'Inventory' | 'StaffPerformance'
  filters         Json      // { dateRange, branchId, categoryId, paymentMode, customerGroup }
  columns         Json      // Array of column definitions
  schedule        Json?     // { frequency, time, dayOfWeek, dayOfMonth, emails, format }
  createdBy       String    // userId who created it
  lastRunAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)

  @@index([businessOwnerId])
  @@index([reportType])
}

model ReportTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  reportType  String   // 'Sales' | 'Products' | 'Customers' | 'Inventory' | 'StaffPerformance'
  filters     Json     // Default filter configuration
  columns     Json     // Default column definitions
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([reportType])
}

model ScheduledReport {
  id              String    @id @default(uuid())
  businessOwnerId String
  customReportId  String
  frequency       String    // 'Daily' | 'Weekly' | 'Monthly'
  time            String    // HH:MM format
  dayOfWeek       Int?      // 0-6 for weekly
  dayOfMonth      Int?      // 1-31 for monthly
  emails          Json      // Array of email addresses
  format          String    @default("CSV") // 'CSV' | 'PDF' | 'Both'
  isActive        Boolean   @default(true)
  lastSentAt      DateTime?
  nextRunAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)

  @@index([businessOwnerId])
  @@index([nextRunAt])
}

// ============================================
// PHASE 11: Payment Gateway Integration (US-222)
// ============================================

// Payment gateway provider enum
enum GatewayProvider {
  Razorpay
  Stripe
  PayU
}

// Online payment status enum
enum OnlinePaymentStatus {
  Created
  Processing
  Completed
  Failed
  Refunded
  PartiallyRefunded
}

// Refund status enum
enum RefundStatus {
  Initiated
  Processing
  Completed
  Failed
}

// Reconciliation status enum
enum ReconciliationStatus {
  Pending
  Reconciled
  Disputed
  Settled
}

// PaymentGatewayConfig - Gateway credentials per business
model PaymentGatewayConfig {
  id              String          @id @default(uuid())
  businessOwnerId String
  provider        GatewayProvider
  apiKey          String          // Encrypted API key
  apiSecret       String          // Encrypted API secret
  webhookSecret   String?         // Encrypted webhook verification secret
  isActive        Boolean         @default(false)
  isTestMode      Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)

  @@unique([businessOwnerId, provider])
  @@index([businessOwnerId])
}

// OnlinePayment - Individual payment transactions via gateway
model OnlinePayment {
  id                   String              @id @default(uuid())
  orderId              String
  amount               Decimal             @db.Decimal(10, 2)
  currency             String              @default("INR")
  gatewayProvider      GatewayProvider
  gatewayTransactionId String?             // Payment ID from gateway (e.g., pay_xxxxx)
  gatewayOrderId       String?             // Order ID from gateway (e.g., order_xxxxx)
  status               OnlinePaymentStatus @default(Created)
  paymentMethod        String?             // card, upi, netbanking, wallet
  failureReason        String?
  metadata             Json?               // Additional gateway-specific data
  paidAt               DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  // Relations
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@index([orderId])
  @@index([gatewayTransactionId])
  @@index([gatewayOrderId])
  @@index([status])
}

// Refund - Refund transactions
model Refund {
  id              String       @id @default(uuid())
  onlinePaymentId String
  amount          Decimal      @db.Decimal(10, 2)
  reason          String?
  status          RefundStatus @default(Initiated)
  gatewayRefundId String?      // Refund ID from gateway
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  onlinePayment OnlinePayment @relation(fields: [onlinePaymentId], references: [id], onDelete: Cascade)

  @@index([onlinePaymentId])
  @@index([status])
}

// PaymentReconciliation - Settlement reconciliation records
model PaymentReconciliation {
  id              String               @id @default(uuid())
  businessOwnerId String
  settlementDate  DateTime             @db.Date
  gatewayProvider GatewayProvider
  totalAmount     Decimal              @db.Decimal(12, 2)
  settledAmount   Decimal              @db.Decimal(12, 2)
  fees            Decimal              @default(0) @db.Decimal(10, 2)
  transactionCount Int                 @default(0)
  status          ReconciliationStatus @default(Pending)
  reconciledAt    DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Relations
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)

  @@index([businessOwnerId])
  @@index([settlementDate])
  @@index([gatewayProvider])
  @@index([status])
}

// ============================================
// PHASE 11: UPI AutoPay Subscriptions (US-237)
// ============================================

// UPI AutoPay subscription status enum
enum AutoPayStatus {
  Created
  Authenticated
  Active
  Paused
  Cancelled
  Completed
  Expired
}

// UPIAutoPaySubscription - Recurring subscription payments via UPI AutoPay
model UPIAutoPaySubscription {
  id                   String        @id @default(uuid())
  businessOwnerId      String
  planId               String
  customerId           String?
  gatewaySubscriptionId String?      // Razorpay subscription_xxxxx
  gatewayProvider      GatewayProvider @default(Razorpay)
  upiId                String?       // Customer's UPI ID (e.g., user@upi)
  amount               Decimal       @db.Decimal(10, 2)
  currency             String        @default("INR")
  interval             String        @default("monthly") // monthly, yearly
  status               AutoPayStatus @default(Created)
  currentStart         DateTime?     // Current billing cycle start
  currentEnd           DateTime?     // Current billing cycle end
  nextBillingDate      DateTime?
  totalCount           Int?          // Total number of billing cycles (null = infinite)
  paidCount            Int           @default(0) // Number of successful payments
  failedCount          Int           @default(0) // Number of failed payment attempts
  lastPaymentAt        DateTime?
  lastPaymentId        String?       // Gateway payment ID of last charge
  failureReason        String?
  metadata             Json?
  cancelledAt          DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Relations
  businessOwner BusinessOwner    @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([businessOwnerId])
  @@index([planId])
  @@index([gatewaySubscriptionId])
  @@index([status])
  @@index([nextBillingDate])
}

// ============================================
// PHASE 12: Third-party Integration Tables (US-240)
// ============================================

// Integration type enum
enum IntegrationType {
  accounting
  delivery
  marketing
  payment
  review_management
  loyalty
  crm
  notifications
  inventory
  security
  hardware
  attendance
  voice_assistant
}

// Integration provider enum
enum IntegrationProvider {
  tally
  quickbooks
  zoho_books
  dunzo
  porter
  whatsapp_business
  sms_gateway
  google_my_business
  email_marketing
  loyalty_points
  hubspot
  salesforce
  slack
  supplier_portal
  cctv
  pos_hardware
  biometric
  voice_ordering
}

// Integration status enum
enum IntegrationStatus {
  active
  inactive
  error
}

// Integration - Third-party integration configurations for a business
model Integration {
  id              String              @id @default(uuid())
  businessOwnerId String
  provider        IntegrationProvider
  type            IntegrationType
  config          Json // API credentials, endpoints, settings
  status          IntegrationStatus   @default(inactive)
  lastSyncAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  businessOwner BusinessOwner    @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)
  logs          IntegrationLog[]

  @@unique([businessOwnerId, provider])
  @@index([businessOwnerId])
  @@index([provider])
}

// IntegrationLog - Audit trail for integration sync operations
model IntegrationLog {
  id              String   @id @default(uuid())
  integrationId   String
  action          String // e.g., "sync_invoice", "sync_order", "send_message"
  status          String // "success", "failure", "pending"
  requestPayload  Json? // Request data sent to third-party
  responsePayload Json? // Response data from third-party
  errorMessage    String?
  createdAt       DateTime @default(now())

  // Relations
  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([createdAt])
}

// CustomerReview - Google reviews and other platform reviews
model CustomerReview {
  id               String    @id @default(uuid())
  businessOwnerId  String
  externalReviewId String    @unique
  source           String    @default("google") // google, zomato, swiggy
  reviewerName     String
  rating           Int // 1-5
  comment          String?   @db.Text
  replyText        String?   @db.Text
  repliedAt        DateTime?
  publishedAt      DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)

  @@index([businessOwnerId])
  @@index([publishedAt])
  @@index([rating])
}

// SecurityCamera - CCTV camera locations and configuration (US-260)
model SecurityCamera {
  id              String   @id @default(uuid())
  businessOwnerId String
  branchId        String
  name            String // e.g., "Dining Area Cam 1", "Kitchen Cam"
  location        String // e.g., "Main Hall", "Kitchen", "Entrance"
  cameraId        String // External camera/NVR identifier
  streamUrl       String? // RTSP or HTTP stream URL
  nvrHost         String? // NVR/DVR host address
  nvrPort         Int?    // NVR/DVR port
  protocol        String  @default("http") // http, rtsp, onvif
  status          String  @default("active") // active, inactive, maintenance
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([businessOwnerId, cameraId])
  @@index([businessOwnerId])
  @@index([branchId])
}

// StaffAttendance - Biometric attendance records for staff (US-262)
model StaffAttendance {
  id              String   @id @default(uuid())
  businessOwnerId String
  branchId        String
  staffId         String
  punchType       String // IN, OUT
  punchTime       DateTime
  deviceId        String? // Biometric device identifier
  verifyMode      String? // fingerprint, face, card, pin
  workHours       Float?  // Calculated total work hours for the shift
  shiftDate       DateTime // The calendar date of the shift (normalized to midnight)
  createdAt       DateTime @default(now())

  // Relations
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  staff         Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([businessOwnerId])
  @@index([branchId])
  @@index([staffId])
  @@index([shiftDate])
  @@index([punchTime])
}

// ============================================
// PHASE 13: Advanced RBAC (US-265)
// ============================================

// Permission - Fine-grained permission definitions
model Permission {
  id          String   @id @default(uuid())
  module      String // e.g., catalog, inventory, orders, settings
  action      String // e.g., create, read, update, delete, approve, export
  resource    String? // e.g., product, category, order (optional sub-resource)
  description String?
  createdAt   DateTime @default(now())

  // Relations
  rolePermissions RolePermission[]

  @@unique([module, action, resource])
  @@index([module])
}

// RolePermission - Links roles to permissions
model RolePermission {
  id           String  @id @default(uuid())
  roleId       String
  permissionId String
  granted      Boolean @default(true) // Explicit grant or deny

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// UserRoleAssignment - Assigns roles to users with optional scope (branch/kitchen)
model UserRoleAssignment {
  id        String    @id @default(uuid())
  userId    String // Staff ID (or BusinessOwner ID)
  roleId    String
  branchId  String? // Optional branch scope
  kitchenId String? // Optional kitchen scope
  expiresAt DateTime? // For temporary access grants
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  branch  Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)
  kitchen Kitchen? @relation(fields: [kitchenId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, branchId, kitchenId])
  @@index([userId])
  @@index([roleId])
  @@index([branchId])
  @@index([kitchenId])
}

// PermissionAuditLog - Tracks permission checks for auditing
model PermissionAuditLog {
  id           String   @id @default(uuid())
  userId       String
  action       String // The action attempted (e.g., create, update, delete)
  resource     String // The resource type (e.g., product, order)
  resourceId   String? // The specific resource instance ID
  granted      Boolean // Whether permission was granted
  deniedReason String? // Reason for denial
  ipAddress    String? // IP address of the request
  timestamp    DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
  @@index([granted])
  @@index([resource])
}

// ============================================
// Menu Visibility Configuration (Dynamic Sidebar)
// ============================================

// MenuVisibility - Controls which sidebar menu items are visible per user type
model MenuVisibility {
  id        String   @id @default(uuid())
  userType  String   // 'SuperAdmin' | 'BusinessOwner' | 'Staff'
  menuKey   String   // e.g. 'pos', 'catalog', 'sa_dashboard'
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userType, menuKey])
  @@index([userType])
}

// ============================================
// Loyalty Program
// ============================================

// LoyaltyTransaction - Tracks points awarded/redeemed per customer
model LoyaltyTransaction {
  id              String   @id @default(uuid())
  customerId      String
  branchId        String
  businessOwnerId String
  type            String   // 'award' | 'redeem'
  points          Int
  description     String?
  orderId         String?
  createdAt       DateTime @default(now())

  // Relations
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([branchId])
  @@index([businessOwnerId])
  @@index([orderId])
}

// ============================================
// Supplier Rating
// ============================================

// SupplierRating - Business owner's rating for a supplier
model SupplierRating {
  id              String   @id @default(uuid())
  supplierId      String
  businessOwnerId String
  rating          Int      // 1-5
  comment         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  supplier      Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  businessOwner BusinessOwner @relation(fields: [businessOwnerId], references: [id], onDelete: Cascade)

  @@unique([supplierId, businessOwnerId])
  @@index([supplierId])
  @@index([businessOwnerId])
}
